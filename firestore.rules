rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read of cached scores so the map loads fast
    match /hex_scores/{doc}    { allow read: if true; allow write: if false; }
    match /poi_cache/{doc}     { allow read: if true; allow write: if false; }
    match /realestate/{doc}    { allow read: if true; allow write: if false; }
    // Shared analysis snapshots — public read so a share link opens for anyone;
    // writes happen server-side via the Admin SDK (rules don't apply there).
    match /shared_results/{doc} { allow read: if true; allow write: if false; }

    // Per-user data
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
